# ============================================================================
# JIJU environment. Copy to .env.local for local dev; set the same keys in
# Vercel Project Settings -> Environment Variables for production.
# ============================================================================

# ---- Generation provider: Kimi (Moonshot AI), OpenAI-compatible API ----
# KIMI_API_KEY is also accepted as MOONSHOT_API_KEY (the platform's name).
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# ---- SEMrush Analytics REST API (API key WITH units) ----
SEMRUSH_API_KEY=

# ---- App access gate (2 users) ----
# Long random string. Defense-in-depth alongside Google SSO / Vercel protection.
JIJU_ACCESS_TOKEN=

# ---- Defaults ----
ATLYS_BASE_URL=https://www.atlys.com
DEFAULT_LOCALE=en-US
SEMRUSH_DEFAULT_DATABASE=us
